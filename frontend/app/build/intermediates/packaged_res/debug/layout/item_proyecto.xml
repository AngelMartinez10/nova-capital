<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardCornerRadius="14dp"
    app:cardBackgroundColor="#1A2B3C"
    app:cardElevation="4dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Fila superior: nombre + estado -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">

            <TextView
                android:id="@+id/tvNombre"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Nombre del proyecto"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:layout_marginEnd="8dp" />

            <TextView
                android:id="@+id/tvEstado"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ACTIVO"
                android:textSize="10sp"
                android:textStyle="bold"
                android:textColor="#2196F3"
                android:background="@drawable/badge_estado_blue"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:paddingTop="3dp"
                android:paddingBottom="3dp"
                android:letterSpacing="0.05" />

        </LinearLayout>

        <!-- Objetivo e invertido -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="10dp">

            <TextView
                android:id="@+id/tvObjetivo"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Objetivo: 500 Aurus"
                android:textSize="12sp"
                android:textColor="#8899AA" />

            <TextView
                android:id="@+id/tvInvertido"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Invertido: 0 Aurus"
                android:textSize="12sp"
                android:textColor="#4CAF50"
                android:gravity="end" />

        </LinearLayout>

        <!-- Barra de progreso -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="14dp">

            <ProgressBar
                android:id="@+id/progressBar"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="0dp"
                android:layout_height="8dp"
                android:layout_weight="1"
                android:max="100"
                android:progress="0"
                android:progressTint="#F0C040"
                android:progressBackgroundTint="#2A3B4C"
                android:layout_marginEnd="10dp" />

            <TextView
                android:id="@+id/tvPorcentaje"
                android:layout_width="36dp"
                android:layout_height="wrap_content"
                android:text="0%"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="#F0C040"
                android:gravity="end" />

        </LinearLayout>

        <!-- Botón invertir -->
        <Button
            android:id="@+id/btnInvertir"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:text="INVERTIR"
            android:textColor="#0D1B2A"
            android:textStyle="bold"
            android:textSize="13sp"
            android:letterSpacing="0.08"
            android:background="@drawable/btn_primary"
            android:stateListAnimator="@null" />

    </LinearLayout>
</androidx.cardview.widget.CardView>