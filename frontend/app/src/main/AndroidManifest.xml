<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET" />

    <application
        android:allowBackup="true"
        android:label="Nova Capital"
        android:usesCleartextTraffic="true"
        android:supportsRtl="true"
        android:theme="@style/Theme.AppCompat.Light.DarkActionBar">

        <!-- LoginActivity es la pantalla de inicio -->
        <activity
            android:name=".activities.LoginActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity android:name=".activities.RegistroActivity" android:exported="false" />
        <activity android:name=".activities.MainActivity" android:exported="false" />
        <activity android:name=".activities.ListaProyectosActivity" android:exported="false" />
        <activity android:name=".activities.DetalleProyectoActivity" android:exported="false" />
        <activity android:name=".activities.CrearProyectoActivity" android:exported="false" />
        <activity android:name=".activities.PerfilActivity" android:exported="false" />
        <activity android:name=".activities.RetosActivity" android:exported="false" />

    </application>

</manifest>