<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0D1B2A"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Header con saludo y saldo -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            app:cardCornerRadius="20dp"
            app:cardBackgroundColor="#1A2B3C"
            app:cardElevation="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp">

                <TextView
                    android:id="@+id/tvBienvenida"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="¡Hola, Usuario!"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    android:layout_marginBottom="8dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="💎"
                        android:textSize="24sp"
                        android:layout_marginEnd="8dp" />

                    <TextView
                        android:id="@+id/tvSaldo"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Saldo: 1000.00 Aurus"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="#F0C040" />

                </LinearLayout>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Título sección -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="¿Qué quieres hacer?"
            android:textSize="16sp"
            android:textColor="#8899AA"
            android:layout_marginBottom="16dp" />

        <!-- Botón Proyectos -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="14dp"
            app:cardBackgroundColor="#1A2B3C"
            app:cardElevation="4dp">

            <Button
                android:id="@+id/btnProyectos"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:text="  📊  Ver Proyectos de Inversión"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                android:textStyle="bold"
                android:gravity="center_vertical|start"
                android:paddingStart="20dp"
                android:background="@android:color/transparent"
                android:stateListAnimator="@null" />

        </androidx.cardview.widget.CardView>

        <!-- Botón Crear Proyecto -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="14dp"
            app:cardBackgroundColor="#1A2B3C"
            app:cardElevation="4dp">

            <Button
                android:id="@+id/btnCrearProyecto"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:text="  🚀  Crear nuevo Proyecto"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                android:textStyle="bold"
                android:gravity="center_vertical|start"
                android:paddingStart="20dp"
                android:background="@android:color/transparent"
                android:stateListAnimator="@null" />

        </androidx.cardview.widget.CardView>

        <!-- Botón Perfil -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="14dp"
            app:cardBackgroundColor="#1A2B3C"
            app:cardElevation="4dp">

            <Button
                android:id="@+id/btnPerfil"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:text="  👤  Mi Perfil e Historial"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                android:textStyle="bold"
                android:gravity="center_vertical|start"
                android:paddingStart="20dp"
                android:background="@android:color/transparent"
                android:stateListAnimator="@null" />

        </androidx.cardview.widget.CardView>

        <!-- Botón Retos -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            app:cardCornerRadius="14dp"
            app:cardBackgroundColor="#1A2B3C"
            app:cardElevation="4dp">

            <Button
                android:id="@+id/btnRetos"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:text="  🏆  Mis Retos y Logros"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                android:textStyle="bold"
                android:gravity="center_vertical|start"
                android:paddingStart="20dp"
                android:background="@android:color/transparent"
                android:stateListAnimator="@null" />

        </androidx.cardview.widget.CardView>

        <!-- Botón Cerrar Sesión -->
        <Button
            android:id="@+id/btnLogout"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="Cerrar sesión"
            android:textColor="#FF5555"
            android:textSize="13sp"
            android:background="@drawable/btn_danger_outline"
            android:stateListAnimator="@null" />

    </LinearLayout>
</ScrollView>